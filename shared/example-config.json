{
  "app": {
    "name": "Task Manager",
    "version": "1.0.0",
    "description": "A simple task management application",
    "locale": "en",
    "supportedLocales": ["en", "es", "fr"]
  },
  "database": {
    "tables": [
      {
        "name": "tasks",
        "fields": [
          { "name": "title", "type": "string", "required": true },
          { "name": "description", "type": "text", "required": false },
          { "name": "status", "type": "string", "default": "pending" },
          { "name": "priority", "type": "number", "default": 1 },
          { "name": "dueDate", "type": "date", "required": false },
          { "name": "completed", "type": "boolean", "default": false }
        ]
      },
      {
        "name": "projects",
        "fields": [
          { "name": "name", "type": "string", "required": true, "unique": true },
          { "name": "description", "type": "text" },
          { "name": "startDate", "type": "date" },
          { "name": "budget", "type": "number" }
        ]
      }
    ]
  },
  "ui": {
    "pages": [
      {
        "path": "/",
        "title": "Dashboard",
        "type": "dashboard",
        "auth": true,
        "components": [
          { "type": "stats", "dataSource": "tasks" },
          { "type": "chart", "dataSource": "tasks", "chartType": "bar" }
        ]
      },
      {
        "path": "/tasks",
        "title": "Tasks",
        "type": "table",
        "dataSource": "tasks",
        "auth": true,
        "components": [
          { "type": "table", "columns": ["title", "status", "priority", "dueDate"] },
          { "type": "filters", "fields": ["status", "priority"] }
        ]
      },
      {
        "path": "/tasks/new",
        "title": "New Task",
        "type": "form",
        "dataSource": "tasks",
        "auth": true,
        "components": [
          { "type": "input", "field": "title", "label": "Task Title" },
          { "type": "textarea", "field": "description", "label": "Description" },
          { "type": "select", "field": "status", "options": ["pending", "in-progress", "completed"] },
          { "type": "number", "field": "priority", "min": 1, "max": 5 },
          { "type": "date", "field": "dueDate" }
        ]
      }
    ]
  },
  "api": {
    "endpoints": [
      { "path": "/api/tasks", "method": "GET", "table": "tasks", "action": "list", "auth": true },
      { "path": "/api/tasks/:id", "method": "GET", "table": "tasks", "action": "read", "auth": true },
      { "path": "/api/tasks", "method": "POST", "table": "tasks", "action": "create", "auth": true },
      { "path": "/api/tasks/:id", "method": "PUT", "table": "tasks", "action": "update", "auth": true },
      { "path": "/api/tasks/:id", "method": "DELETE", "table": "tasks", "action": "delete", "auth": true },
      { "path": "/api/projects", "method": "GET", "table": "projects", "action": "list", "auth": true },
      { "path": "/api/projects", "method": "POST", "table": "projects", "action": "create", "auth": true }
    ]
  },
  "auth": {
    "enabled": true,
    "methods": ["email", "google"],
    "userFields": ["name", "email", "avatar"]
  }
}
